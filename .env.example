# Optional environment variables

# Pick a provider (optional). If unset, Renovate auto-picks the first available key:
# anthropic → openai → google
# RENOVATE_PROVIDER=anthropic
# RENOVATE_PROVIDER=openai
# RENOVATE_PROVIDER=google

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GOOGLE_GENERATIVE_AI_API_KEY=...
# or: GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# Without any AI key, /renovate runs in demo mode.

# Google Maps API key (enables address search in the editor)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Dev server port (apps/editor defaults to 3002 via its script)
# PORT=3002
