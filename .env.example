# Optional environment variables

# Anthropic API key (enables live Renovate photo analysis)
# Without this, /renovate runs in demo mode.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional Claude model override
# CLAUDE_MODEL=claude-sonnet-4-5

# Google Maps API key (enables address search in the editor)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Dev server port (apps/editor defaults to 3002 via its script)
# PORT=3002
